    {
      "parameters": {
        "jsCode": "// 檢查第一個 item 來判斷資料類型\nconst firstItem = items[0].json;\n\n// 處理 FMP API 回傳的資料 (美股) - 新格式\nif (firstItem.symbol && firstItem.date && firstItem.open !== undefined && !firstItem.stock_id) {\n  const pricesData = items.map(item => ({\n    date: item.json.date,\n    open: item.json.open,\n    high: item.json.high,\n    low: item.json.low,\n    close: item.json.close,\n    volume: item.json.volume\n  }));\n  \n  return [{\n    json: {\n      code: firstItem.symbol,\n      market: \"USA\",\n      prices: JSON.stringify(pricesData)\n    }\n  }];\n}\n\n// 處理 FinMind API 回傳的資料 (台股) - 保持原樣\nreturn items.map(item => {\n  if (item.json.data && item.json.data.length > 0) {\n    const pricesData = item.json.data.map(day => ({\n      date: day.date,\n      open: day.open,\n      high: day.max,\n      low: day.min,\n      close: day.close,\n      volume: day.Trading_Volume\n    }));\n    \n    return {\n      json: {\n        code: item.json.data[0].stock_id,\n        market: \"TW\",\n        prices: JSON.stringify(pricesData)\n      }\n    };\n  }\n  \n  return { json: {} };\n});"
      },
