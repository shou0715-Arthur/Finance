    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  // 處理 FMP API 回傳的資料 (美股)\n  if (item.json.historical) {\n    const pricesData = item.json.historical.map(day => ({\n      date: day.date,\n      open: day.open,\n      high: day.high,\n      low: day.low,\n      close: day.close,\n      volume: day.volume\n    }));\n    \n    return {\n      json: {\n        code: item.json.symbol,\n        market: \"USA\",\n        prices: JSON.stringify(pricesData)  // 移除格式化參數，變成緊湊格式\n      }\n    };\n  }\n  \n  // 處理 FinMind API 回傳的資料 (台股)\n  if (item.json.data && item.json.data.length > 0) {\n    const pricesData = item.json.data.map(day => ({\n      date: day.date,\n      open: day.open,\n      high: day.max,\n      low: day.min,\n      close: day.close,\n      volume: day.Trading_Volume\n    }));\n    \n    return {\n      json: {\n        code: item.json.data[0].stock_id,\n        market: \"TW\",\n        prices: JSON.stringify(pricesData)  // 移除格式化參數，變成緊湊格式\n      }\n    };\n  }\n  \n  return { json: {} };\n});"
      },
